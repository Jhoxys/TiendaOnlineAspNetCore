      let contador = 0;
    function printPDF(boton) {

    if (contador === 0) {
            boton.textContent = 'Printing...';
            boton.disabled = true;
            var inputs = document.querySelectorAll('#formPrinc input');
         //   inputs.forEach(input => input.disabled = true);

            inputs.forEach(input => { input.disabled = true });

            var pdfUrl = "@ViewBag.PdfPath";
            contador++
            var win = window.open(pdfUrl, "_blank");
            win.print();

        }
  

    }

    function DebtUser(check) {
        var inputs = document.querySelector('#SpentInput input');

        inputs.disabled = true;

        if (check.checked) {
            check.value = true;
            document.getElementById("DebtActiver").value = 1;
            document.getElementById("BillingTitle").innerHTML = "<span class='text-danger'>Account to Pay</span>";
						
        } else {
            inputs.disabled = false;
            document.getElementById("DebtActiver").value = 0;
            document.getElementById("BillingTitle").innerHTML = "Billing";
            check.value = false; 
        }

    }

    function SpenttUser(check) {
        var inputs = document.querySelector('#DebtInput input');
        inputs.disabled = true;

        if (check.checked) {
            check.value = true;
            document.getElementById("DebtActiver").value = 2;
            document.getElementById("BillingTitle").innerHTML = " <span class='text-danger'>Spent to Pay</span>";
            document.getElementById

        } else {
            inputs.disabled = false;
            document.getElementById("DebtActiver").value = 0;
            document.getElementById("BillingTitle").innerHTML = "Billing";
            check.value = false; 
        }

    }



</script>





