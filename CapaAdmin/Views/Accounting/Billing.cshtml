                            <form class="d-flex" role="search">
                                <input class="form-control me-2" type="search" name="search" value="@search" placeholder="Search Name and Brand" aria-label="Search">
                                <button class="btn btn-outline-success"  type="submit">Seach</button>
                            </form>
                        </div>
                        <hr/>
                        <div class="row">
                            <table class="table table-striped table-borderless"  id="AddTableProduct">
                                <thead>
                                    <tr>
                                      <th style="cursor: pointer;" onclick="sortTable('Name')">Name </th>
                                      <th style="cursor: pointer;" onclick="sortTable('Brand')">Brand  </th>
                                      <th style="cursor: pointer;" onclick="sortTable('Category')">Category  </th>
                                      <th style="cursor: pointer;" onclick="sortTable('Price')">Price  </th>
                                      <th>Image</th>
                                        <th>Stock</th>
                                        <th>Code</th>
                                      <th style="cursor: pointer;" onclick="sortTable('CreatedAt')"> Descrition</th>
                                      <th>Action</th>
                                        <th style="display:none">ID</th>
                                    </tr>

                                </thead>
                                <tbody>

                                    @if (ViewBag.ProductSeach !=null)
                                    {
                                        
                                 
                                    @foreach (var product in ViewBag.ProductSeach)
                                {

                                    <tr>
                                        <td>@product.Name</td>
                                        <td>@product.Brand</td>
                                        <td>@product.Category</td>
                                        <td>@(product.Price)</td>
                                        <td><img src="/img/@product.ImageFileName" width="100" /></td>
                                        <td>@(product.Stock)</td>
                                        <td>@(product.CodeProduct)</td>
                                        <td>@product.Description </td>
                                            <td>
                                             <button type="button" onclick="addProcut(this)" class="btn btn-danger text-capitalize active" aria-pressed="true">
                                                Agregar
                                            </button>
                                            </td>
                                            <td style="display:none">@product.Id </td>
                                    </tr>

                                }
                                    }
                                </tbody>
                            </table>

                        </div>


                    </div>
                    </div>

                </div>
                </div>
               
        </div>
    </div>
    </div>
        <div class="col-xl-4">

            <div class="card">
				<div class="card-body">
                <h6 class="mb-1">Facturas Generadas</h6>
                <div class="text-muted small mb-3">Historial de facturas y métodos de pago</div>

                <!-- Ejemplo de factura (luego lo pones con foreach) -->
                    @foreach (var factura in ViewBag.Facturas)
                    {
                        <form method="post" asp-action="DescargarPDF" >
                        <div class="invoice-card p-3 mb-3">
                  
                                <input class="form-control"  asp-for="BillingDto[0].NoFactura"  value="@factura.NoFactura" hidden />
                                @* <input class="form-control" name="NoFactura" value="@factura.NoFactura" hidden /> *@


                            <button type="submit" class="btn btn-link p-0 m-0" style="font-size: 20px;">
                                <i class="fas fa-print"></i>
                                imprimir
                            </button>
                                @if (factura.Debt[0] == 1)
                                {
                               <h5> <span class="text-danger">Account to Pay</span></h5>
                            
                                    
                                }
                                @if (factura.Debt[0] == 2)
                                {
                                    <h5> <span class="text-danger">Spent to Pay</span></h5>
                               
                                }
                            <div class="d-flex align-items-start justify-content-between">
                                <div>
                                        <div class="invoice-title"> @factura.NameSeller </div>
                                    @* <div class="text-muted small">Telefono • @factura.Phone</div> *@
                                        <div class="text-muted small">@factura.CreatedAt.ToString("g")</div>
                                </div>
                                   
                                  
                                <div class="text-end">
                                        @{
											decimal TotalAndITB = 0;
                                            var calITB = (Convert.ToDecimal(ViewBag.ITBISCalculo) * factura.Totalitys );
                                            if (factura.Checks >= 1)
                                            {
                                                TotalAndITB = (factura.Totalitys + calITB);
                                            }else {
                                                TotalAndITB = factura.Totalitys;
											}
                       
                                            <div class="invoice-amount">@TotalAndITB.ToString("N2")</div>

                                        }
                                    <div class="text-muted small">
                                          
                                            @if (factura.Checks >= 1)
                                                {  
                                               
                                                <span class="text-bold"> ITBIS: </span>
                                              
                                                @calITB.ToString("N2");

                                                }
                                                else
                                                {
                                                    <span class="text-danger">No ITBIS</span>
                                                }

                                            
                                    </div>
                                   
                                    <div class="mt-2">
                                        <span class="pill">
                                            <i class="bi bi-wallet2"></i> Efectivo
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Hidden Inputs -->
                        <input type="hidden" name="NoFactura" value="@factura.NoFactura" />
                        @* <input type="hidden" name="Phone" value="@factura.Phone" /> *@
                        <input type="hidden" name="CreatedAt" value="@factura.CreatedAt" />
                            <input type="hidden" name="Total" value="@( Convert.ToDecimal(ViewBag.ITBIS) * factura.Totalitys ))" />
                            <input type="hidden" name="ITB" value="@( Convert.ToDecimal(ViewBag.ITBIS) * factura.Totalitys ))" />
                        @* <input type="hidden" name="MetodoPago" value="@factura.MetodoPago" /> *@

                    </form>


                }
                    <nav aria-label="Menu pagination">
                        <ul class="pagination">
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var active = i == pageIndex ? "active" : "";
                                <li class="page-item @active">
                                    <a class="page-link"
                                       asp-route-pageIndex="@i"
                                     >@i</a>
                                </li>
                            }
                        </ul>
                    </nav>



                <!-- Más .invoice-card con foreach -->
            </div>
            </div>


    </div>
 
</section>
