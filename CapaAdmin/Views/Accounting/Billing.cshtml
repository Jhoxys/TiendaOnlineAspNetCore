            btn.appendChild = '<i class="bi bi-cart4"></i>';
       btn.textContent = 'Store'; // Cambiar el texto del botón a "Store"
		} else {
			ArtControl.style.display = 'block'; // Mostrar el div si está oculto


		}                
    }
